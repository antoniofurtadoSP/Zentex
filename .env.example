# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EFI BANK (PAYMENT GATEWAY) CONFIGURATION
# Client ID from the Efí Developer Console
EFI_CLIENT_ID=""
# Client Secret from the Efí Developer Console
EFI_CLIENT_SECRET=""
# Set to 'true' to use the sandbox/homologacao environment (defaults to 'false' for real production payments)
EFI_SANDBOX="false"
# Your registered Pix Key (Chave Pix)
EFI_PIX_KEY=""
# Path to the P12 certificate file (relative to root)
EFI_CERT_PATH="certs/homologacao.p12"
# Alternatively, provide the certificate file content as a Base64-encoded string (recommended for cloud deploys like Render)
EFI_CERT_BASE64=""
# Optional password associated with the certificate
EFI_CERT_PASSWORD=""

# Account Identifier (Identificador de Conta) for the credit card tokenization CDN script
EFI_ACCOUNT_CODE=""

# Dynamic port for production hosting platforms like Render
PORT=3000
